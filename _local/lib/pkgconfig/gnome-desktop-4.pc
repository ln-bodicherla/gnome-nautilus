prefix=/Users/lnbodicherla/Documents/gnome-nautilus/_local
includedir=${prefix}/include
libdir=${prefix}/lib

Name: gnome-desktop-4
Description: Utility library for GNOME desktop components
Version: 44.5
Requires: gsettings-desktop-schemas >=  3.27.0
Requires.private: gdk-pixbuf-2.0 >=  2.36.5, glib-2.0 >=  2.53.0, gio-2.0 >=  2.53.0, gio-unix-2.0 >=  2.53.0, xkeyboard-config, xkbregistry, iso-codes
Libs: -L${libdir} -lgnome-desktop-4
Libs.private: -lm
Cflags: -I${includedir}/gnome-desktop-4.0
