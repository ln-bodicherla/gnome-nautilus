prefix=/Users/lnbodicherla/Documents/gnome-nautilus/_local
includedir=${prefix}/include
libdir=${prefix}/lib

exec_prefix=${prefix}
extensiondir=${libdir}/nautilus/extensions-4
extensions_api_version=4

Name: libnautilus-extension
Description: A library to create Nautilus view extensions
Version: 50.rc
Requires: gio-2.0, glib-2.0
Libs: -L${libdir} -lnautilus-extension
Cflags: -I${includedir}/nautilus
